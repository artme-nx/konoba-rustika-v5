{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "stone": {
        "950": { "$value": "#1B1712", "$type": "color" },
        "900": { "$value": "#24201A", "$type": "color" },
        "800": { "$value": "#362F26", "$type": "color" },
        "600": { "$value": "#5C5040", "$type": "color" },
        "400": { "$value": "#9C8D71", "$type": "color" },
        "200": { "$value": "#D6C9AB", "$type": "color" },
        "100": { "$value": "#EDE3CB", "$type": "color" }
      },
      "timber": {
        "900": { "$value": "#3E2515", "$type": "color" },
        "700": { "$value": "#6B3E20", "$type": "color" },
        "500": { "$value": "#8F5A2E", "$type": "color" }
      },
      "ember": {
        "600": { "$value": "#C1440E", "$type": "color" },
        "700": { "$value": "#9A3609", "$type": "color" },
        "900": { "$value": "#4A1904", "$type": "color" }
      },
      "wine": {
        "700": { "$value": "#5C1A2E", "$type": "color" },
        "900": { "$value": "#341019", "$type": "color" }
      },
      "parchment": {
        "50": { "$value": "#F6EEDA", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-fraunces), 'Fraunces', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-source-sans), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-geist-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1s", "$type": "duration" },
        "beam": { "$value": "1.4s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "timber": { "$value": "cubic-bezier(0.22, 0.68, 0.34, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.stone.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "card": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "popover": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "primary": { "$value": "{primitive.color.ember.600}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "muted": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.stone.400}", "$type": "color" },
    "accent": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.wine.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "input": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "ring": { "$value": "{primitive.color.ember.600}", "$type": "color" },
    "radius": { "$value": "0.125rem", "$type": "dimension" },
    "ember": { "$value": "{primitive.color.ember.600}", "$type": "color" },
    "ember-dim": { "$value": "{primitive.color.ember.900}", "$type": "color" },
    "timber": { "$value": "{primitive.color.timber.700}", "$type": "color" },
    "timber-dark": { "$value": "{primitive.color.timber.900}", "$type": "color" },
    "timber-light": { "$value": "{primitive.color.timber.500}", "$type": "color" },
    "wine": { "$value": "{primitive.color.wine.700}", "$type": "color" },
    "stone-line": { "$value": "{primitive.color.stone.600}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-timber": { "$value": "{primitive.motion.ease.timber}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "beam": {
      "height": { "$value": "clamp(2.25rem, 5vw, 4.5rem)", "$type": "dimension" },
      "grain": {
        "$value": "repeating-linear-gradient(100deg, rgba(0,0,0,0.16) 0px, rgba(0,0,0,0.16) 2px, transparent 2px, transparent 5px), linear-gradient(180deg, #7A4A26 0%, #5A3419 48%, #3E2415 100%)",
        "$type": "gradient"
      }
    },
    "wall": {
      "texture": {
        "$value": "radial-gradient(circle at 20% 30%, rgba(255,255,255,0.035) 0, transparent 40%), radial-gradient(circle at 70% 70%, rgba(0,0,0,0.25) 0, transparent 45%), radial-gradient(circle at 85% 15%, rgba(255,255,255,0.025) 0, transparent 35%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.ember.600}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.ember.700}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.stone.600}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.parchment.50}", "$type": "color" }
    }
  }
}
